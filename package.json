{
  "name": "playground",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:web": "npm run dev -w @playground/web",
    "dev:api": "npm run dev -w @playground/api",
    "build": "npm run build -w @playground/shared && npm run build -w @playground/game-engine && npm run build -w @playground/api && npm run build -w @playground/web",
    "db:generate": "npm run db:generate -w @playground/api",
    "db:migrate": "npm run db:migrate -w @playground/api",
    "db:push": "npm run db:push -w @playground/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.7.3"
  }
}
